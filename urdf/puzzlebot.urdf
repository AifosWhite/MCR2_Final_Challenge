<?xml version="1.0"?>
<robot name="puzzlebot">

  <!-- Base Footprint Link -->
  <link name="base_footprint"/>

  <!-- Base Link (center of the robot) -->
  <link name="base_link">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://puzzlebot_sim2/meshes/Puzzlebot_Jetson_Lidar_Edition_Base(1).stl" scale="1 1 1"/>
      </geometry>
      <material name="white">
        <color rgba="1.0 1.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://puzzlebot_sim2/meshes/Puzzlebot_Jetson_Lidar_Edition_Base(1).stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <!-- Right Wheel Link -->
  <link name="wheel_r_link">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
      <geometry>
        <mesh filename="package://puzzlebot_sim2/meshes/Puzzlebot_Wheel.stl" scale="1 1 1"/>
      </geometry>
      <material name="black">
        <color rgba="0.02 0.02 0.02 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
      <geometry>
        <mesh filename="package://puzzlebot_sim2/meshes/Puzzlebot_Wheel.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <!-- Left Wheel Link -->
  <link name="wheel_l_link">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>

      <geometry>
        <mesh filename="package://puzzlebot_sim2/meshes/Puzzlebot_Wheel.stl" scale="1 1 1"/>
      </geometry>
      <material name="black">
        <color rgba="0.02 0.02 0.02 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
      <geometry>
        <mesh filename="package://puzzlebot_sim2/meshes/Puzzlebot_Wheel.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <!-- Caster Wheel Link -->
  <link name="caster_link">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://puzzlebot_sim2/meshes/Puzzlebot_Caster_Wheel.stl" scale="1 1 1"/>
      </geometry>
      <material name="caster_black">
        <color rgba="0.02 0.02 0.02 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://puzzlebot_sim2/meshes/Puzzlebot_Caster_Wheel.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>


  <!-- LiDAR visual body.
       The physical RPLidar mesh is attached to lidar_base_link.
       The actual scan frame is laser_frame, placed slightly above the mesh. -->
  <link name="lidar_base_link">
    <inertial>
      <origin xyz="0.0 0.0 0.021" rpy="0.0 0.0 0.0"/>
      <mass value="0.1755"/>
      <inertia ixx="0.000108225" ixy="0.0" ixz="0.0"
               iyy="0.0001301625" iyz="0.0" izz="0.0001652625"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.025" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://puzzlebot_sim2/meshes/RPLidar.stl" scale="1 1 1"/>
      </geometry>
      <material name="lidar_grey">
        <color rgba="0.25 0.25 0.25 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.021" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.08 0.07 0.05"/>
      </geometry>
    </collision>
  </link>

  <!-- LaserScan reference frame.
       Navigation nodes should use data published in this frame. -->
  <link name="laser_frame">
    <inertial>
      <mass value="0.00001"/>
      <inertia ixx="0.0000000000417" ixy="0.0" ixz="0.0"
               iyy="0.0000000000417" iyz="0.0" izz="0.0000000000417"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.005 0.005 0.005"/>
      </geometry>
      <material name="laser_frame_blue">
        <color rgba="0.0 0.2 1.0 0.6"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.005 0.005 0.005"/>
      </geometry>
    </collision>
  </link>

  <!-- JOINTS -->

  <!-- Fixed joint between base_footprint and base_link (z-axis offset) -->
  <joint name="base_link_joint" type="fixed">
    <origin xyz="0.0 0.0 0.05" rpy="0.0 0.0 0.0"/>
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  <!-- Right Wheel Joint -->
  <joint name="wheel_r_joint" type="continuous">
    <origin xyz="0.052 -0.095 -0.0025" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="wheel_r_link"/>
    <axis xyz="0.0 -1.0 0.0"/>
  </joint>

  <!-- Left Wheel Joint -->
  <joint name="wheel_l_joint" type="continuous">
    <origin xyz="0.052 0.095 -0.0025" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="wheel_l_link"/>
    <axis xyz="0.0 1.0 0.0"/>
  </joint>

  <!-- Caster Joint -->
  <joint name="caster_joint" type="fixed">
    <origin xyz="-0.09 0 -0.043" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="caster_link"/>
  </joint>

  <!-- LiDAR base mounted on top/front of the robot.
       Values are taken from the official Puzzlebot ROS2 description. -->
  <joint name="lidar_base_joint" type="fixed">
    <origin xyz="0.0425 0.0 0.070" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="lidar_base_link"/>
  </joint>

  <!-- Scan frame located above the LiDAR body. -->
  <joint name="lidar_joint" type="fixed">
    <origin xyz="0.0 0.0 0.035" rpy="0.0 0.0 0.0"/>
    <parent link="lidar_base_link"/>
    <child link="laser_frame"/>
  </joint>

  <!-- Gazebo LiDAR sensor.
       This block is used when the URDF is spawned in Gazebo/Gz.
       The ROS navigation node expects this data as /scan. -->
  <gazebo reference="laser_frame">
    <sensor name="lidar_sensor" type="gpu_lidar">
      <topic>/scan</topic>
      <gz_frame_id>laser_frame</gz_frame_id>
      <pose>0 0 0 0 0 0</pose>
      <update_rate>10</update_rate>
      <always_on>true</always_on>
      <visualize>false</visualize>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>0.01</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>0.0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.017</resolution>
        </range>
      </ray>
    </sensor>
  </gazebo>

</robot>
